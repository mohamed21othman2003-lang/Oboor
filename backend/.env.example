# انسخ هذا الملف إلى .env واملأ القيم الحقيقية (لا تضع الأسرار الحقيقية هنا)
# cp .env.example .env

# ===== Django =====
DJANGO_SECRET_KEY=ضع-مفتاحًا-عشوائيًا-طويلًا
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ===== قاعدة بيانات Supabase (Postgres) =====
# مهم: للـ migrations استخدم "Session pooler" (port 5432) أو الاتصال المباشر،
#       لأن "Transaction pooler" (6543) لا يدعم كل عمليات الـ migration.
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ===== حساب المدير الأول (اختياري) =====
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=ضع-كلمة-مرور-قوية

# ===== تخزين الصور على Supabase Storage (S3) =====
# القيم من: Supabase → Project Settings → Storage → S3 Connection
SUPABASE_S3_ENDPOINT=https://xxxx.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-west-1
SUPABASE_S3_BUCKET=media
# مفاتيح الوصول من: Supabase → Storage → S3 Access Keys
SUPABASE_S3_KEY=ضع-الـ-Access-Key
SUPABASE_S3_SECRET=ضع-الـ-Secret-Key

# ===== البريد الإلكتروني (لرسائل إعادة تعيين كلمة المرور) =====
# اترك EMAIL_HOST فارغًا لطباعة الرسائل في سجلّ الخادم (بدون إرسال فعلي).
# املأ القيم لتفعيل الإرسال عبر SMTP (Gmail / Google Workspace / SendGrid…).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Oboor <no-reply@oboor.ido.sa>
# الرابط العام للواجهة لبناء روابط إعادة التعيين
FRONTEND_URL=https://oboor.ido.sa
