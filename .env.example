# متغيّرات الواجهة (Next.js) — انسخ إلى .env.local واملأ القيم الحقيقية
# cp .env.example .env.local

# رابط الـAPI بتاع Django كما يراه سيرفر Next.js (server-side).
# محلياً: http://127.0.0.1:8000  |  في الإنتاج: رابط الباك إند المنشور.
DJANGO_API_URL=http://127.0.0.1:8000

# نفس الرابط لكن للمتصفح (client-side). يُدمج وقت البناء (build)،
# فلازم يكون مضبوطاً قبل «next build».
NEXT_PUBLIC_DJANGO_API_URL=http://127.0.0.1:8000

# اتصال قاعدة البيانات (يُستخدم في بعض السكربتات فقط — اتركه فارغاً إن لم تحتَجه).
DATABASE_URL=
