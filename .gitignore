# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent/tooling artifacts
/.playwright-mcp

# design reference exports (not part of the app)
/.claude/figma-refs/

# runtime form submissions
/data

.vercel

# local Claude settings (may contain command logs)
.claude/settings.local.json

# local Python interpreter (embeddable) + installers
/_py/
/pyembed.zip
/python-*.exe
